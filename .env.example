# Q-BharatAI-System Environment Variables Template
# Copy this file to '.env' and fill in your values.

# --- VITE APP PORT CONFIG ---
VITE_PORT=5173

# --- GOOGLE GEMINI AI CONFIGURATION ---
# Get your API key from Google AI Studio: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-1.5-flash

# --- FIREBASE SERVICES CONFIGURATION ---
# Retrieve these credentials from your Firebase Console (Project Settings -> General)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=q-bharatai-system.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=q-bharatai-system
VITE_FIREBASE_STORAGE_BUCKET=q-bharatai-system.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# --- GOOGLE MAPS PLATFORM CONFIG ---
# Required for locating nearby PHCs and spatial disease outbreak tracking
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- BACKEND API BASE URL (For Production Deployment) ---
VITE_API_BASE_URL=http://localhost:5000/api/v1
